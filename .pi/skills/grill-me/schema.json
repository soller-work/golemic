{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/grill-me/schema.json",
  "title": "Autonomously Implementable Vertical Slice v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slice_type",
    "change_type",
    "title",
    "stakeholder",
    "trigger",
    "success_outcome",
    "tldr",
    "scope",
    "behavior",
    "business_rules",
    "acceptance_scenarios",
    "inputs_outputs_errors",
    "verify_commands",
    "definition_of_done",
    "readiness"
  ],
  "properties": {
    "slice_type": {
      "type": "string",
      "enum": [
        "command",
        "query",
        "process",
        "integration"
      ]
    },
    "change_type": {
      "type": "string",
      "enum": [
        "feature",
        "bug",
        "refactoring"
      ],
      "description": "Intent/proof category: feature=new or changed user-visible capability, bug=regression/defect fix, refactoring=internal technical improvement without intended behavior change."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "stakeholder": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "string",
      "minLength": 1
    },
    "success_outcome": {
      "type": "string",
      "minLength": 1
    },
    "tldr": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in",
        "out"
      ],
      "properties": {
        "in": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "behavior": {
      "type": "string",
      "minLength": 1,
      "description": "Free-form Markdown: for commandâ†’state mutations, queryâ†’read model, processâ†’ordered steps, integrationâ†’external contract."
    },
    "business_rules": {
      "type": "string",
      "minLength": 0,
      "description": "Free-form Markdown with business rules and decision logic."
    },
    "acceptance_scenarios": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Each item is a free-form 'Given ... When ... Then ...' string."
    },
    "inputs_outputs_errors": {
      "type": "string",
      "minLength": 1,
      "description": "Free-form Markdown: contract, validation, error handling."
    },
    "verify_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Commands to verify implementation (tests, linting, etc.)."
    },
    "definition_of_done": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Completion criteria; e.g., 'All tests pass', 'Code reviewed'."
    },
    "codebase_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "location",
          "note"
        ],
        "properties": {
          "location": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Evidence from codebase: {location: 'path:line', note: 'finding'}."
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "text"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "question",
              "assumption",
              "blocker"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Unified blocker list: {kind: 'question'|'assumption'|'blocker', text: '...'}"
    },
    "security_relevant": {
      "type": "boolean",
      "default": false,
      "description": "Set true if slice has security implications."
    },
    "security": {
      "type": "string",
      "minLength": 1,
      "description": "Free-form Markdown on security considerations; only required if security_relevant=true."
    },
    "readiness": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ],
      "description": "Set by finalize command; ready iff blockers empty and validation passes."
    }
  },
  "if": {
    "properties": {
      "security_relevant": {
        "const": true
      }
    }
  },
  "then": {
    "required": [
      "security"
    ]
  }
}
