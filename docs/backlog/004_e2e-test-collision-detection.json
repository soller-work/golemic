  "slice_id": "e2e-test-collision-detection",
  "depends_on": [
    "e2e-test-happy-path-all-steps-succeed"
  ],
  "title": "E2E Test: Collision detection",
  "summary": "Verify collision detection catches stale artifacts: worktree/branch/PR exists. Each failure scenario exits 1 with cleanup command.",
  "stakeholder_intent": {
    "actor": "Test engineer",
    "goal": "Validate collision check prevents data loss from stale artifacts",
    "business_value": "Safe retry of failed runs without manual cleanup",
    "trigger": "golemic run invoked with stale artifacts from prior run",
    "success_outcome": "Abort with exit 1 and specific cleanup command (git worktree remove, git push --delete, gh pr close)"
  },
  "scope": {
    "in_scope": [
      "Detect: dev worktree, local/remote branch, open PR",
      "Provide cleanup commands"
    ],
    "out_of_scope": [
      "Auto-cleanup"
    ]
  },
  "preconditions": [
    "Preflight passes",
    "Issue loads",
    "Test can create stale artifacts"
  ],
  "business_rules": [
    {
      "id": "BR-001",
      "rule": "Collision check must run before any worktree creation",
      "applies_when": "Post-preflight",
      "outcome": "If collision found, abort with exit 1"
    },
    {
      "id": "BR-002",
      "rule": "Error must include exact cleanup command",
      "applies_when": "Collision detected",
      "outcome": "User can run command to fix"
    }
  ],
  "process_steps": [
    {
      "id": "PS-001",
      "order": 1,
      "name": "Preflight and issue load",
      "trigger": "Run starts",
      "action": "Preflight and load (assume pass)",
      "state_before": "Setup",
      "state_after": "Ready for collision check",
      "outcome": "Preflight OK, issue loaded",
      "failure_behavior": "N/A for this issue",
      "terminal": false
    },
    {
      "id": "PS-002",
      "order": 2,
      "name": "Collision check",
      "trigger": "Issue loaded",
      "action": "Query git and GitHub for stale artifacts",
      "state_before": "stale artifacts may exist",
      "state_after": "Collision found or none",
      "outcome": "Collision detected or check passes",
      "failure_behavior": "Exit 1 with cleanup command if collision",
      "terminal": true
    }
  ],
  "interfaces": [
    {
      "id": "IF-001",
      "kind": "cli",
      "name": "golemic run (with collision)",
      "operation": "golemic run --issue N (with stale artifacts)",
      "inputs": [
        {
          "name": "--issue",
          "type": "int",
          "required": true,
          "constraints": [
            "positive"
          ],
          "source": "cli"
        }
      ],
      "outputs": [
        {
          "condition": "no collision",
          "status": "exit 0 (continue)",
          "body": "Collision check passes; proceed"
        }
      ],
      "errors": [
        {
          "condition": "dev worktree exists",
          "code": "1",
          "status": "exit 1",
          "message": "Cleanup: git worktree remove ~/.golemic/..."
        },
        {
          "condition": "local branch collision",
          "code": "1",
          "status": "exit 1",
          "message": "Cleanup: git branch -D ..."
        },
        {
          "condition": "remote branch collision",
          "code": "1",
          "status": "exit 1",
          "message": "Cleanup: git push --delete ..."
        },
        {
          "condition": "open PR collision",
          "code": "1",
          "status": "exit 1",
          "message": "Cleanup: gh pr close ..."
        }
      ]
    }
  ],
  "state_changes": [],
  "side_effects": [],
  "security": {
    "authentication": "Read-only checks",
    "authorization_rules": [
      "Read-only queries; no credentials needed"
    ],
    "data_classification": "Test",
    "audit_requirements": []
  },
  "implementation_context": {
    "target_modules": [
      "test/e2e/"
    ],
    "integration_points": [
      "Creating stale git objects and GitHub PRs",
      "Querying git and GitHub"
    ],
    "architecture_constraints": [
      "Check must run synchronously before any modifications"
    ],
    "allowed_changes": [
      "Test helpers to create stale artifacts"
    ],
    "forbidden_changes": [
      "Do not modify collision detection logic"
    ],
    "dependencies": [],
    "migration_strategy": "Additive",
    "consistency_and_concurrency": "Serial; each test cleans up"
  },
  "acceptance_scenarios": [
    {
      "id": "AC-001",
      "title": "Dev worktree collision detected",
      "given": [
        "Stale dev worktree exists"
      ],
      "when": [
        "golemic run"
      ],
      "then": [
        "Collision found",
        "Cleanup command in stderr",
        "Exit 1"
      ],
      "traces_to": [
        "BR-001",
        "BR-002",
        "PS-002",
        "IF-001",
        "PS-001"
      ]
    },
    {
      "id": "AC-002",
      "title": "Local branch collision detected",
      "given": [
        "Local branch golemic/issue-N exists"
      ],
      "when": [
        "golemic run"
      ],
      "then": [
        "Collision found",
        "Exit 1"
      ],
      "traces_to": [
        "BR-001",
