  "slice_id": "e2e-test-preflight-failures",
  "title": "E2E Test: Preflight failures",
  "summary": "Verify that each preflight check failure is caught: gh/pi missing, .golemic/ missing, config invalid, tokens identical/missing. Exit code 1 before GitHub access.",
  "stakeholder_intent": {
    "actor": "Test engineer",
    "goal": "Validate preflight rejects misconfigured environments early",
    "business_value": "Prevents silent failures or unintended GitHub actions",
    "trigger": "golemic run invoked with missing/broken prerequisites",
    "success_outcome": "Each scenario exits 1 with clear error; no GitHub API calls"
  },
  "scope": {
    "in_scope": [
      "gh missing, pi missing, .golemic/ missing, config.json invalid, credentials identical/missing",
      "Exit 1 on any failure"
    ],
    "out_of_scope": [
      "Issue loading, GitHub operations"
    ]
  },
  "preconditions": [
    "golemic binary available",
    "Test can manipulate PATH, files, and environment variables",
    "Test issue number available"
  ],
  "business_rules": [
    {
      "id": "BR-001",
      "rule": "Fail-closed: abort immediately on first check failure",
      "applies_when": "Any check fails",
      "outcome": "Exit 1; error to stderr"
    },
    {
      "id": "BR-002",
      "rule": "Tokens must be distinct",
      "applies_when": "Credentials checked",
      "outcome": "Reject if GOLEMIC_DEV_TOKEN == GOLEMIC_REVIEWER_TOKEN"
    }
  ],
  "process_steps": [
    {
      "id": "PS-001",
      "order": 1,
      "name": "Run checks",
      "trigger": "golemic run invoked",
      "action": "Execute 6 preflight checks in order",
      "state_before": "Environment may be broken",
      "state_after": "First failure found or all pass",
      "outcome": "Check result",
      "failure_behavior": "Abort on first failure",
      "terminal": true
    },
    {
      "id": "PS-002",
      "order": 2,
      "name": "Record error",
      "trigger": "Check fails",
      "action": "Log error",
      "state_before": "Failure detected",
      "state_after": "Error reported",
      "outcome": "Error",
      "failure_behavior": "Abort",
      "terminal": true
    }
  ],
  "interfaces": [
    {
      "id": "IF-001",
      "kind": "cli",
      "name": "golemic run (broken env)",
      "operation": "golemic run --issue N (with missing/broken prereq)",
      "inputs": [
        {
          "name": "--issue",
          "type": "int",
          "required": true,
          "constraints": [
            "positive"
          ],
          "source": "cli"
        },
        {
          "name": "environment",
          "type": "string",
          "required": false,
          "constraints": [
            "may be missing tools"
          ],
          "source": "PATH and env vars"
        }
      ],
      "outputs": [
        {
          "condition": "any check fails",
          "status": "exit 1",
          "body": "stderr: error message"
        }
      ],
      "errors": [
        {
          "condition": "gh missing",
          "code": "1",
          "status": "exit 1",
          "message": "FEHLT: gh installiert"
        },
        {
          "condition": "pi missing",
          "code": "1",
          "status": "exit 1",
          "message": "FEHLT: pi installiert"
        },
        {
          "condition": "config invalid",
          "code": "1",
          "status": "exit 1",
